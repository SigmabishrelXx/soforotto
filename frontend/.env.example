# Base URL of your deployed Sub0 project. When this is set, the app talks to
# your real backend (inquiries, the Wall, and the live AI proxy).
# Leave it unset for local development — the AI chat falls back to demo mode.
VITE_SUB0_API_BASE=https://api.your-sub0-project.lingoql.com

# Optional: base URL for Sub0 websockets. Defaults to VITE_SUB0_API_BASE with
# http(s) swapped for ws(s).
# VITE_SUB0_WS_BASE=wss://api.your-sub0-project.lingoql.com

# Force the AI chat into scripted "demo mode" even when a backend URL is set.
# Useful for recording a demo without spending Anthropic tokens. Set to "true"
# to enable. When unset/false and VITE_SUB0_API_BASE is set, the chat uses the
# real Anthropic proxy (the /ai-chat Sub0 endpoint).
# VITE_AI_DEMO_MODE=false
